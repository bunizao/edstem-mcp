{
  "name": "edstem-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Bun-native remote MCP server for Ed Discussion",
  "packageManager": "bun@1.3.6",
  "type": "module",
  "scripts": {
    "admin": "bun src/admin.ts",
    "build": "bun build src/index.ts src/admin.ts --outdir dist --target bun",
    "check": "bunx tsc --noEmit -p tsconfig.json",
    "db:prune": "bun src/admin.ts prune-expired",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.21",
    "typescript": "^5.8.3"
  }
}
